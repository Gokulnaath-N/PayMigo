{
  "name": "paymigo-frontend-root",
  "version": "1.0.0",
  "private": true,
  "description": "Root management for Paymigo Frontend",
  "workspaces": [
    "web"
  ],
  "scripts": {
    "dev": "npm run dev -w web",
    "build": "npm run build -w web",
    "preview": "npm run preview -w web",
    "lint": "npm run lint -w web",
    "server": "npx tsx web/api/server.ts",
    "clean": "npm run clean -w web",
    "install:all": "npm install"
  },
  "devDependencies": {
    "tsx": "^4.21.0"
  }
}
